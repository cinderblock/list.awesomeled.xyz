{
  "name": "awesomeledlist",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:links": "textlint \"database/**/*.yaml\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "spell": "cspell .",
    "spell:check": "cspell --no-progress .",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:visual": "playwright test --project=visual --workers=1",
    "agent-review": "bun run scripts/agent-review.ts",
    "review": "bun run scripts/review-entry.ts",
    "validate": "bun run scripts/validate.ts",
    "mirror-datasheets": "bun run scripts/mirror-datasheets.ts"
  },
  "dependencies": {
    "@mdx-js/rollup": "^3.1.1",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-router/node": "7.13.0",
    "@react-router/serve": "7.13.0",
    "isbot": "^5.1.34",
    "jszip": "^3.10.1",
    "lucide-react": "^0.563.0",
    "marked": "^17.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "7.13.0",
    "rehype-external-links": "^3.0.0",
    "sharp": "^0.34.5",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.58.1",
    "@react-router/dev": "7.13.0",
    "@textlint-rule/textlint-rule-no-invalid-control-character": "^3.0.0",
    "@textlint/textlint-plugin-text": "^15.5.1",
    "@types/node": "^25.2.0",
    "@types/react": "^19.2.11",
    "@types/react-dom": "^19.2.3",
    "ajv": "^8.20.0",
    "cspell": "^9.6.4",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-yml": "^3.0.0",
    "prettier": "^3.8.1",
    "textlint": "^15.5.1",
    "textlint-filter-rule-allowlist": "^4.0.0",
    "textlint-rule-doubled-spaces": "^1.0.2",
    "textlint-rule-no-dead-link": "^6.2.1",
    "textlint-rule-no-todo": "^2.0.1",
    "textlint-rule-terminology": "^5.2.16",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vite": "^7.3.1",
    "vite-plugin-devtools-json": "^1.0.0",
    "vite-tsconfig-paths": "^6.0.5",
    "yaml-eslint-parser": "^2.0.0"
  }
}
