# Copy this file to `.env.local` (or `.env`) and fill in the values.
# Both are gitignored — only `.env.example` is committed.

# Cloudflare API token (NOT your global API key).
# Create one at: https://dash.cloudflare.com/profile/api-tokens
# Required permission (minimum): Account -> Cloudflare Pages -> Read
CLOUDFLARE_API_TOKEN=

# Cloudflare Account ID.
# Find it in the dashboard sidebar under Workers & Pages -> Overview,
# or in the URL: https://dash.cloudflare.com/<this-is-your-account-id>
CLOUDFLARE_ACCOUNT_ID=

# Pages project name. Defaults to "awesomeledlist" if left unset.
# This is the subdomain in https://<project>.pages.dev
CLOUDFLARE_PAGES_PROJECT=awesomeledlist
