{
  "plugins": {
    "@textlint/text": {
      "extensions": [".yaml", ".yml"]
    }
  },
  "filters": {
    "allowlist": {
      "allow": ["/^\\s*[a-z_-]+:/m"]
    }
  },
  "rules": {
    "no-dead-link": {
      "checkRelative": false,
      "ignore": [],
      "preferGET": [],
      "ignoreRedirects": false,
      "retry": 1,
      "concurrency": 100,
      "intervalCap": 200,
      "maxRetryTime": 5
    }
  }
}
