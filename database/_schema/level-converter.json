{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://awesomeledlist.com/schema/level-converter.json",
  "title": "Level Converter",
  "type": "object",
  "required": ["name"],
  "properties": {
    "name": {
      "type": "string"
    },
    "creator": {
      "type": ["string", "null"],
      "description": "Original designer/developer of this item"
    },
    "manufacturers": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Manufacturers that produce this item"
    },
    "vendors": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Vendors that sell/distribute this item"
    },
    "channels": {
      "type": ["integer", "null"]
    },
    "interface": {
      "type": ["string", "null"]
    },
    "notes": {
      "type": ["string", "null"]
    },
    "price": {
      "type": ["string", "number", "null"]
    },
    "max_voltage": {
      "type": ["string", "number", "null"]
    },
    "max_current": {
      "type": ["string", "number", "null"]
    },
    "buffered": {
      "type": ["boolean", "null"]
    },
    "url": {
      "type": ["string", "null"]
    }
  }
}
