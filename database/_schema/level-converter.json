{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://awesomeled.xyz/schema/level-converter.json",
  "title": "Level Converter",
  "type": "object",
  "required": ["name"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string"
    },
    "status": {
      "anyOf": [
        {
          "$ref": "common.json#/definitions/status"
        },
        {
          "type": "null"
        }
      ]
    },
    "creator": {
      "anyOf": [
        {
          "type": ["string", "null"]
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string"
            },
            "url": {
              "type": "string"
            },
            "page": {
              "type": "string"
            }
          }
        }
      ]
    },
    "manufacturers": {
      "type": ["array", "null"],
      "items": {
        "type": "string"
      }
    },
    "vendors": {
      "type": ["array", "null"],
      "items": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string"
              },
              "url": {
                "type": "string"
              },
              "page": {
                "type": "string"
              }
            }
          }
        ]
      }
    },
    "notes": {
      "type": ["string", "null"]
    },
    "price": {
      "description": "Single price (USD unless {amount, currency}) or published quantity tiers",
      "oneOf": [
        { "$ref": "common.json#/definitions/price" },
        { "$ref": "common.json#/definitions/price_tiers" }
      ]
    },
    "io": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "channels": {
          "type": ["integer", "null"]
        },
        "interface": {
          "type": ["string", "null"]
        },
        "buffered": {
          "type": ["boolean", "null"]
        }
      }
    },
    "electrical": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "max_voltage": {
          "type": ["string", "number", "null"]
        },
        "max_current": {
          "type": ["string", "number", "null"]
        }
      }
    },
    "links": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "product": {
          "type": ["string", "null"]
        }
      }
    },
    "image": {
      "$ref": "common.json#/definitions/image"
    },
    "images": {
      "$ref": "common.json#/definitions/images"
    },
    "related": {
      "$ref": "common.json#/definitions/related"
    },
    "dead_links": {
      "$ref": "common.json#/definitions/dead_links"
    }
  }
}
