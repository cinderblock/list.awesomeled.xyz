{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://awesomeled.xyz/schema/adapter.json",
  "title": "Adapter",
  "type": "object",
  "required": ["name"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string"
    },
    "status": {
      "anyOf": [
        {
          "$ref": "common.json#/definitions/status"
        },
        {
          "type": "null"
        }
      ]
    },
    "creator": {
      "anyOf": [
        {
          "type": ["string", "null"]
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string"
            },
            "url": {
              "type": "string"
            },
            "page": {
              "type": "string"
            }
          }
        }
      ]
    },
    "manufacturers": {
      "type": ["array", "null"],
      "items": {
        "type": "string"
      }
    },
    "vendors": {
      "type": ["array", "null"],
      "items": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string"
              },
              "url": {
                "type": "string"
              },
              "page": {
                "type": "string"
              }
            }
          }
        ]
      }
    },
    "notes": {
      "type": ["string", "null"]
    },
    "price": {
      "type": ["string", "number", "null"]
    },
    "diy_or_ots": {
      "type": ["string", "null"],
      "description": "DIY, OTS (off-the-shelf), or both"
    },
    "parent": {
      "type": ["string", "null"],
      "description": "Parent board/platform required"
    },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "physical": {
          "type": "object",
          "additionalProperties": {},
          "description": "Physical inputs (Wi-Fi, Ethernet, SD card, ...) as key: value/true"
        },
        "protocols": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Control protocols accepted (Art-Net, E1.31, DMX512, ...)"
        }
      }
    },
    "software": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "firmware": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Firmware the adapter runs or is built for (FPP, WLED, ESPixelStick)"
        },
        "works_with": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Software commonly paired with it (xLights, WLED)"
        }
      }
    },
    "outputs": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "max_channels": {
          "type": ["integer", "null"]
        },
        "pixel_types": {
          "type": ["string", "null"],
          "description": "async, clocked, both, ..."
        },
        "connectors": {
          "type": ["string", "null"]
        },
        "description": {
          "type": ["string", "null"]
        }
      }
    },
    "power": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "voltage": {
          "type": ["string", "number", "null"]
        },
        "current": {
          "type": ["string", "number", "null"]
        }
      }
    },
    "links": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "product": {
          "type": ["string", "null"]
        }
      }
    },
    "related_microboards": {
      "type": ["array", "null"],
      "items": {
        "type": "string"
      }
    },
    "related_connectors": {
      "type": ["array", "null"],
      "items": {
        "type": "string"
      }
    },
    "image": {
      "$ref": "common.json#/definitions/image"
    },
    "images": {
      "$ref": "common.json#/definitions/images"
    },
    "related": {
      "$ref": "common.json#/definitions/related"
    },
    "dead_links": {
      "$ref": "common.json#/definitions/dead_links"
    }
  }
}
