{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://awesomeledlist.com/schema/adapter.json",
  "title": "Adapter",
  "type": "object",
  "required": ["name"],
  "additionalProperties": false,
  "properties": {
    "name": { "type": "string" },
    "status": {
      "anyOf": [{ "$ref": "common.json#/definitions/status" }, { "type": "null" }]
    },
    "creator": {
      "anyOf": [
        { "type": ["string", "null"] },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": { "type": "string" },
            "url": { "type": "string" },
            "page": { "type": "string" }
          }
        }
      ]
    },
    "manufacturers": { "type": ["array", "null"], "items": { "type": "string" } },
    "vendors": {
      "type": ["array", "null"],
      "items": {
        "anyOf": [
          { "type": "string" },
          {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "url": { "type": "string" },
              "page": { "type": "string" }
            }
          }
        ]
      }
    },
    "notes": { "type": ["string", "null"] },
    "price": { "type": ["string", "number", "null"] },
    "diy_or_ots": { "type": ["string", "null"], "description": "DIY, OTS (off-the-shelf), or both" },
    "parent": { "type": ["string", "null"], "description": "Parent board/platform required" },

    "outputs": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "max_channels": { "type": ["integer", "null"] },
        "pixel_types": { "type": ["string", "null"], "description": "async, clocked, both, ..." },
        "connectors": { "type": ["string", "null"] },
        "description": { "type": ["string", "null"] }
      }
    },

    "power": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "voltage": { "type": ["string", "number", "null"] },
        "current": { "type": ["string", "number", "null"] }
      }
    },

    "links": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "product": { "type": ["string", "null"] }
      }
    },

    "related_microboards": { "type": ["array", "null"], "items": { "type": "string" } },
    "related_connectors": { "type": ["array", "null"], "items": { "type": "string" } },

    "image": { "$ref": "common.json#/definitions/image" },
    "images": { "$ref": "common.json#/definitions/images" }
  }
}
