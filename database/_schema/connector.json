{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://awesomeledlist.com/schema/connector.json",
  "title": "Connector",
  "type": "object",
  "required": ["name"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string"
    },
    "status": {
      "anyOf": [
        {
          "$ref": "common.json#/definitions/status"
        },
        {
          "type": "null"
        }
      ]
    },
    "year_introduced": {
      "type": ["integer", "null"],
      "description": "Year first introduced (0/null if unknown)"
    },
    "creator": {
      "anyOf": [
        {
          "type": ["string", "null"]
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string"
            },
            "url": {
              "type": "string"
            },
            "page": {
              "type": "string"
            }
          }
        }
      ],
      "description": "Originating manufacturer; does not imply off-brand incompatibility"
    },
    "manufacturers": {
      "type": ["array", "null"],
      "items": {
        "type": "string"
      }
    },
    "vendors": {
      "type": ["array", "null"],
      "items": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string"
              },
              "url": {
                "type": "string"
              },
              "page": {
                "type": "string"
              }
            }
          }
        ]
      }
    },
    "notes": {
      "type": ["string", "null"]
    },
    "aliases": {
      "type": ["array", "null"],
      "items": {
        "type": "string"
      }
    },
    "common_applications": {
      "type": ["array", "null"],
      "items": {
        "type": "string"
      }
    },
    "ratings": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "max_current": {
          "description": "Per-contact current rating",
          "$ref": "common.json#/definitions/current"
        },
        "max_current_notes": {
          "type": ["string", "null"]
        },
        "max_voltage": {
          "$ref": "common.json#/definitions/voltage"
        },
        "ip_rating": {
          "type": ["string", "null"],
          "description": "IP rating when mated"
        },
        "ip_rating_notes": {
          "type": ["string", "null"]
        }
      }
    },
    "mechanical": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "outline": {
          "type": ["string", "null"],
          "description": "Rectangular, Circular, Triangular"
        },
        "contact_type": {
          "type": ["string", "null"],
          "description": "Pin, blade, socket, ..."
        },
        "pitch": {
          "type": ["string", "null"],
          "description": "Pin-to-pin spacing"
        },
        "min_pins": {
          "type": ["integer", "null"]
        },
        "max_pins": {
          "type": ["integer", "null"]
        },
        "rows": {
          "type": ["integer", "string", "null"]
        },
        "gendered": {
          "type": ["boolean", "null"],
          "description": "Distinct male/female versions"
        },
        "locking": {
          "type": ["string", "null"],
          "description": "Friction, Latching, Screw Lock, ..."
        },
        "panel_mount": {
          "type": ["boolean", "null"]
        },
        "wire_to_wire": {
          "type": ["boolean", "null"]
        },
        "pcb_mount": {
          "type": ["string", "boolean", "null"]
        },
        "board_fingers": {
          "type": ["boolean", "null"]
        }
      }
    },
    "termination": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "solder": {
          "type": ["boolean", "null"]
        },
        "screw_terminal": {
          "type": ["boolean", "null"]
        },
        "crimp": {
          "type": ["boolean", "null"]
        },
        "crimp_tool": {
          "type": ["string", "null"]
        },
        "crimp_tool_cost": {
          "type": ["string", "null"]
        },
        "idc": {
          "type": ["boolean", "null"],
          "description": "Insulation displacement connection"
        },
        "smallest_gauge": {
          "type": ["string", "null"],
          "description": "Smallest wire gauge (AWG)"
        },
        "largest_gauge": {
          "type": ["string", "null"],
          "description": "Largest wire gauge (AWG)"
        }
      }
    },
    "wiring": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "pinout": {
          "type": ["string", "null"]
        },
        "convention": {
          "type": ["string", "null"]
        },
        "colors": {
          "type": ["string", "null"],
          "description": "Available housing colors"
        }
      }
    },
    "links": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "product": {
          "type": ["string", "null"]
        },
        "digikey": {
          "type": ["string", "null"]
        },
        "mouser": {
          "type": ["string", "null"]
        }
      }
    },
    "technical_notes": {
      "type": ["array", "null"],
      "items": {
        "type": "string"
      }
    },
    "image": {
      "$ref": "common.json#/definitions/image"
    },
    "images": {
      "$ref": "common.json#/definitions/images"
    },
    "related": {
      "$ref": "common.json#/definitions/related"
    },
    "dead_links": {
      "$ref": "common.json#/definitions/dead_links"
    }
  }
}
