{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://awesomeledlist.com/schema/drive-library.json",
  "title": "Drive Library",
  "type": "object",
  "required": ["name"],
  "properties": {
    "name": {
      "type": "string"
    },
    "creator": {
      "type": ["string", "null"],
      "description": "Original designer/developer of this item (preferred over developer)"
    },
    "developer": {
      "type": ["string", "null"],
      "description": "Alias for creator (deprecated, use creator instead)"
    },
    "hardware": {
      "type": ["string", "null"],
      "description": "Supported hardware platforms"
    },
    "features": {
      "type": ["string", "null"]
    },
    "url": {
      "type": ["string", "null"]
    },
    "youtube_url": {
      "type": ["string", "null"]
    },
    "instructional_resources": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
