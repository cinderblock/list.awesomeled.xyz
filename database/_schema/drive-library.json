{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://awesomeledlist.com/schema/drive-library.json",
  "title": "Drive Library",
  "type": "object",
  "required": ["id", "name"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "name": {
      "type": "string"
    },
    "developer": {
      "type": ["string", "null"]
    },
    "hardware": {
      "type": ["string", "null"],
      "description": "Supported hardware platforms"
    },
    "features": {
      "type": ["string", "null"]
    },
    "url": {
      "type": ["string", "null"]
    },
    "youtube_url": {
      "type": ["string", "null"]
    },
    "instructional_resources": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
