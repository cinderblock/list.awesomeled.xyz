{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://awesomeledlist.com/schema/commercial-system.json",
  "title": "Commercial Pixel System",
  "type": "object",
  "required": ["name"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string"
    },
    "status": {
      "anyOf": [
        {
          "$ref": "common.json#/definitions/status"
        },
        {
          "type": "null"
        }
      ]
    },
    "since": {
      "type": ["integer", "null"],
      "description": "Year the system was introduced"
    },
    "creator": {
      "anyOf": [
        {
          "type": ["string", "null"]
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string"
            },
            "url": {
              "type": "string"
            },
            "page": {
              "type": "string"
            }
          }
        }
      ]
    },
    "manufacturers": {
      "type": ["array", "null"],
      "items": {
        "type": "string"
      }
    },
    "vendors": {
      "type": ["array", "null"],
      "items": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string"
              },
              "url": {
                "type": "string"
              },
              "page": {
                "type": "string"
              }
            }
          }
        ]
      }
    },
    "notes": {
      "type": ["string", "null"]
    },
    "target_market": {
      "type": ["string", "null"]
    },
    "core_tech": {
      "type": ["string", "null"]
    },
    "specs": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "pixels_per_run": {
          "type": ["integer", "null"]
        },
        "dimming_resolution": {
          "type": ["string", "null"]
        },
        "color_type": {
          "type": ["string", "null"],
          "description": "RGB, RGBW, WW, ..."
        },
        "dedicated_psu": {
          "type": ["boolean", "null"]
        }
      }
    },
    "pricing": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "price_range": {
          "type": ["string", "null"],
          "description": "$ to $$$$$$"
        },
        "online_pricing": {
          "type": ["string", "null"]
        }
      }
    },
    "links": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "product": {
          "type": ["string", "null"]
        }
      }
    },
    "image": {
      "$ref": "common.json#/definitions/image"
    },
    "images": {
      "$ref": "common.json#/definitions/images"
    },
    "related": {
      "$ref": "common.json#/definitions/related"
    }
  }
}
