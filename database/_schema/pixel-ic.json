{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://awesomeledlist.com/schema/pixel-ic.json",
  "title": "Pixel IC",
  "description": "Standalone pixel driver IC (not integrated with LEDs)",
  "type": "object",
  "required": ["name"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string"
    },
    "status": {
      "anyOf": [
        {
          "$ref": "common.json#/definitions/status"
        },
        {
          "type": "null"
        }
      ]
    },
    "release_year": {
      "type": ["integer", "null"]
    },
    "creator": {
      "anyOf": [
        {
          "type": ["string", "null"]
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string"
            },
            "url": {
              "type": "string"
            },
            "page": {
              "type": "string"
            }
          }
        }
      ]
    },
    "manufacturers": {
      "type": ["array", "null"],
      "items": {
        "type": "string"
      }
    },
    "vendors": {
      "type": ["array", "null"],
      "items": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string"
              },
              "url": {
                "type": "string"
              },
              "page": {
                "type": "string"
              }
            }
          }
        ]
      }
    },
    "notes": {
      "type": ["string", "null"]
    },
    "data": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "description": "Signalling / protocol characteristics",
      "properties": {
        "type": {
          "type": ["string", "null"],
          "description": "Protocol family (WS2811, APA102, DMX512, ...)"
        },
        "clocked": {
          "type": ["boolean", "null"]
        },
        "channels": {
          "type": ["integer", "null"],
          "description": "Number of output channels"
        },
        "bitrate": {
          "$ref": "common.json#/definitions/frequency"
        },
        "bitrate_notes": {
          "type": ["string", "null"]
        },
        "pixel_size_bits": {
          "type": ["integer", "null"],
          "description": "Total bits per pixel on the data line (e.g. 24 for 3x8-bit RGB, 32 for APA102 frames). pixel_rate_max is DERIVED from bitrate / pixel_size_bits at build time - do not store it."
        },
        "backup_line": {
          "type": ["boolean", "null"]
        },
        "max_per_string": {
          "type": ["integer", "string", "null"]
        },
        "max_per_string_notes": {
          "type": ["string", "null"]
        }
      }
    },
    "color": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "channel_bits": {
          "type": ["integer", "string", "null"],
          "description": "Bits per channel"
        },
        "aggregate_bits": {
          "type": ["integer", "string", "null"],
          "description": "Total bits across channels"
        },
        "brightness_bits": {
          "type": ["integer", "string", "null"]
        },
        "brightness_method": {
          "type": ["string", "null"],
          "description": "pwm | current | global"
        },
        "pwm_frequency": {
          "$ref": "common.json#/definitions/frequency"
        },
        "pwm_frequency_notes": {
          "type": ["string", "null"]
        }
      }
    },
    "electrical": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "output_voltage": {
          "description": "Output voltage to LEDs (Vds max)",
          "$ref": "common.json#/definitions/voltage"
        },
        "output_voltage_notes": {
          "type": ["string", "null"]
        },
        "supply_voltage": {
          "description": "IC supply voltage (VCC)",
          "$ref": "common.json#/definitions/voltage"
        },
        "supply_voltage_notes": {
          "type": ["string", "null"]
        },
        "gpio": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "properties": {
            "min": {
              "$ref": "common.json#/definitions/voltage"
            },
            "max": {
              "$ref": "common.json#/definitions/voltage"
            },
            "notes": {
              "type": ["string", "null"]
            }
          }
        },
        "max_current": {
          "description": "Max current per channel",
          "$ref": "common.json#/definitions/current"
        },
        "max_current_notes": {
          "type": ["string", "null"]
        },
        "current_programmable": {
          "type": ["boolean", "null"]
        },
        "current_range": {
          "type": ["string", "null"]
        },
        "quiescent_current": {
          "$ref": "common.json#/definitions/current"
        }
      }
    },
    "physical": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "package_sizes": {
          "type": ["array", "null"],
          "items": {
            "type": "string"
          }
        },
        "package_size": {
          "type": ["string", "null"]
        },
        "pin_count": {
          "type": ["integer", "string", "null"]
        }
      }
    },
    "datasheet": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "url": {
          "type": ["string", "null"],
          "description": "Original/manufacturer datasheet URL (attribution)"
        },
        "mirror": {
          "$ref": "common.json#/definitions/datasheet_mirror"
        },
        "discrepancies": {
          "type": ["array", "null"],
          "items": {
            "type": "string"
          }
        },
        "third_party_testing": {
          "type": ["string", "null"]
        }
      }
    },
    "other_links": {
      "type": ["array", "null"],
      "items": {
        "type": "string"
      }
    },
    "technical_notes": {
      "type": ["array", "null"],
      "items": {
        "type": "string"
      }
    },
    "image": {
      "$ref": "common.json#/definitions/image"
    },
    "images": {
      "$ref": "common.json#/definitions/images"
    },
    "related": {
      "$ref": "common.json#/definitions/related"
    },
    "dead_links": {
      "$ref": "common.json#/definitions/dead_links"
    }
  }
}
