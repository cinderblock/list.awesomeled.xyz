{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://awesomeledlist.com/schema/pixel-decoder.json",
  "title": "Pixel Decoder",
  "type": "object",
  "required": ["name"],
  "properties": {
    "name": {
      "type": "string"
    },
    "creator": {
      "type": ["string", "null"],
      "description": "Original designer/developer of this item"
    },
    "manufacturers": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Manufacturers that produce this item"
    },
    "vendors": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Vendors that sell/distribute this item"
    },
    "max_channels": {
      "type": ["integer", "null"]
    },
    "pixel_types": {
      "type": ["string", "null"]
    },
    "price": {
      "type": ["string", "number", "null"]
    },
    "output_connectors": {
      "type": ["string", "null"]
    },
    "outputs": {
      "type": ["string", "null"]
    },
    "diy_or_ots": {
      "type": ["string", "null"]
    },
    "notes": {
      "type": ["string", "null"]
    },
    "url": {
      "type": ["string", "null"]
    }
  }
}
