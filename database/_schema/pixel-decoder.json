{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://awesomeledlist.com/schema/pixel-decoder.json",
  "title": "Pixel Decoder",
  "type": "object",
  "required": ["id", "name"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "name": {
      "type": "string"
    },
    "manufacturer": {
      "type": ["string", "null"]
    },
    "max_channels": {
      "type": ["integer", "null"]
    },
    "pixel_types": {
      "type": ["string", "null"]
    },
    "price": {
      "type": ["string", "number", "null"]
    },
    "output_connectors": {
      "type": ["string", "null"]
    },
    "outputs": {
      "type": ["string", "null"]
    },
    "diy_or_ots": {
      "type": ["string", "null"]
    },
    "notes": {
      "type": ["string", "null"]
    },
    "url": {
      "type": ["string", "null"]
    }
  }
}
