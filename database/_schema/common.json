{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://awesomeledlist.com/schema/common.json",
  "definitions": {
    "status": {
      "type": "string",
      "enum": ["active", "discontinued", "end-of-life", "limited", "unknown"]
    },
    "url": {
      "type": "string",
      "format": "uri"
    },
    "image": {
      "description": "Filename of image in the images/ subdirectory",
      "type": ["string", "null"]
    },
    "images": {
      "description": "Array of image filenames in the images/ subdirectory",
      "type": ["array", "null"],
      "items": { "type": "string" }
    },
    "price": {
      "oneOf": [
        { "type": "number", "minimum": 0 },
        { "type": "string", "pattern": "^\\$?[0-9,]+\\.?[0-9]*$" },
        { "type": "string", "enum": ["free", "varies", "contact", "unknown"] }
      ]
    },
    "voltage": {
      "oneOf": [{ "type": "number" }, { "type": "string", "pattern": "^[0-9]+\\.?[0-9]*\\s*V?$" }]
    },
    "current": {
      "oneOf": [
        { "type": "number" },
        { "type": "string", "pattern": "^[0-9]+\\.?[0-9]*\\s*(m?A)?$" }
      ]
    },
    "year": {
      "oneOf": [{ "type": "integer", "minimum": 1990, "maximum": 2030 }, { "type": "null" }]
    },
    "datasheet_mirror": {
      "type": ["object", "null"],
      "description": "Repo-managed copy of the datasheet PDF on Cloudflare R2. Written by CI (scripts/mirror-datasheets.ts) - do not edit by hand. The original author/source URL stays in datasheet.url.",
      "additionalProperties": false,
      "required": ["url", "sha256", "retrieved", "source"],
      "properties": {
        "url": { "type": "string", "format": "uri", "description": "Public R2 URL of the mirrored PDF" },
        "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "retrieved": { "type": "string", "format": "date" },
        "source": {
          "type": "string",
          "format": "uri",
          "description": "datasheet.url at fetch time; a changed source triggers re-mirroring"
        }
      }
    }
  }
}
