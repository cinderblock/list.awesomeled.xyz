{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://awesomeledlist.com/schema/controller.json",
  "title": "LED Controller",
  "type": "object",
  "required": ["name"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "description": "Product name"
    },
    "status": {
      "type": ["string", "null"],
      "enum": ["active", "discontinued", "end-of-life", "limited", null]
    },
    "release_year": {
      "type": ["integer", "null"],
      "description": "Year of first market availability"
    },
    "creator": {
      "oneOf": [
        { "type": "string" },
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": { "type": "string" },
            "url": { "type": "string", "format": "uri" },
            "page": { "type": "string", "format": "uri" }
          },
          "required": ["name"]
        }
      ],
      "description": "Original designer/developer"
    },
    "manufacturers": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Manufacturers that produce this item"
    },
    "vendors": {
      "type": "array",
      "items": {
        "oneOf": [
          { "type": "string" },
          {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "url": { "type": "string", "format": "uri" },
              "page": { "type": "string", "format": "uri" },
              "warranty": { "type": "string" }
            },
            "required": ["name"]
          }
        ]
      },
      "description": "Vendors that sell/distribute this item"
    },
    "notes": {
      "type": ["string", "null"],
      "description": "High level notes"
    },
    "core": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "IC": { "type": "string", "description": "Microcontroller part number" },
        "family": { "type": "string", "description": "Processor family (STM32, ESP32, etc.)" },
        "clock": { "type": "number", "description": "Clock speed in Hz" },
        "flash": { "type": "integer", "description": "Flash memory in bytes" }
      },
      "description": "Microcontroller/processor details"
    },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "physical": {
          "type": "object",
          "additionalProperties": {
            "oneOf": [
              { "type": "string" },
              { "type": "boolean" },
              { "type": "integer" },
              { "type": "array", "items": { "type": "string" } }
            ]
          },
          "description": "Physical interfaces (Ethernet, Wi-Fi, USB, Bluetooth, buttons, etc.)"
        },
        "protocols": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Data protocols (Art-Net, sACN, etc.)"
        },
        "standalone": {
          "type": "boolean",
          "description": "Can generate lighting outputs without external inputs"
        },
        "requires_host": {
          "type": ["string", "null"],
          "description": "If controller requires additional hardware (e.g., Raspberry Pi)"
        }
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "connector": {
          "oneOf": [
            { "type": "string" },
            {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "ref": { "type": "string", "description": "Reference to connector in connectors database" },
                "pins": { "type": "integer" }
              }
            }
          ],
          "description": "Output connector type"
        },
        "count": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of pixel data outputs"
        },
        "fuse": {
          "type": ["string", "null"],
          "description": "Fuse type for outputs"
        },
        "driver": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "IC": { "type": ["string", "null"], "description": "Buffer/driver IC" },
            "replaceable": { "type": "boolean" },
            "impedance": { "type": "number" },
            "buffered": { "type": "boolean", "description": "Outputs from buffer driver (true) or direct from CPU (false)" },
            "notes": { "type": "string" }
          },
          "description": "Data line driver details"
        },
        "current": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "max": { "type": "number", "description": "Maximum current per output in amps" }
          }
        },
        "differential": {
          "type": "boolean",
          "description": "Outputs use differential signaling"
        },
        "pixels": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "max_per_output": { "type": "integer", "description": "Maximum pixels per output" }
          }
        },
        "protocols": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Supported pixel protocols (WS2812B, SK6812, APA102, etc.)"
        },
        "clocked": {
          "type": ["string", "boolean"],
          "enum": ["always", "selectable", false, true],
          "description": "Clocked pixel support: always, selectable, or false"
        },
        "auxiliary": {
          "type": "object",
          "additionalProperties": { "type": "integer" },
          "description": "Additional outputs (DMX512, TTL, Servo, etc.) with counts"
        }
      }
    },
    "power": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "connector": {
          "oneOf": [
            { "type": "string" },
            {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "oem": { "type": "string" },
                "type": { "type": "string" },
                "pitch": { "type": "number" },
                "pins": { "type": "integer" },
                "count": { "type": "integer" }
              }
            }
          ],
          "description": "Power input connector"
        },
        "current": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "max": { "type": "number", "description": "Maximum current in amps" }
          }
        },
        "voltage": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "max": { "type": "number" },
            "min": { "type": "number" }
          }
        }
      }
    },
    "case": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "material": { "type": "string" },
        "color": { "type": "string" },
        "dimensions": { "type": "string" },
        "mounting": { "type": "string" },
        "waterproof": {
          "oneOf": [
            { "type": "boolean" },
            { "type": "string", "pattern": "^IP[0-9]{2}$" }
          ],
          "description": "IP rating or false if not waterproof"
        }
      }
    },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "fps": { "type": "integer", "description": "Maximum refresh rate" },
        "size": { "type": "integer", "description": "Maximum data size in bytes" },
        "formats": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Supported color formats (RGB, RGBW, etc.)"
        },
        "bit_depths": {
          "type": "array",
          "items": { "type": "integer" },
          "description": "Supported bit depths"
        },
        "storage": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "type": { "type": "string", "description": "Storage type (SD, uSD, Flash, etc.)" },
                  "max_size": { "type": "integer", "description": "Maximum size in GB" },
                  "features": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                },
                "required": ["type"]
              }
            }
          ]
        }
      }
    },
    "features": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Notable features"
    },
    "images": {
      "$ref": "common.json#/definitions/images"
    },
    "price": {
      "oneOf": [
        { "type": "number" },
        { "type": "string" },
        {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "price": { "type": "number" },
              "pixels": { "type": "integer" }
            },
            "required": ["name", "price"]
          }
        }
      ],
      "description": "Price in USD or array of price tiers"
    },
    "technical_notes": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Detailed technical notes"
    },
    "wled_compatible": {
      "type": "boolean",
      "description": "WLED firmware based or capable of running WLED"
    }
  }
}
