{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://awesomeled.xyz/schema/diffusive-material.json",
  "title": "Diffusive Material",
  "type": "object",
  "required": ["name"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string"
    },
    "creator": {
      "anyOf": [
        {
          "type": ["string", "null"]
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string"
            },
            "url": {
              "type": "string"
            },
            "page": {
              "type": "string"
            }
          }
        }
      ]
    },
    "manufacturers": {
      "type": ["array", "null"],
      "items": {
        "type": "string"
      }
    },
    "vendors": {
      "type": ["array", "null"],
      "items": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string"
              },
              "url": {
                "type": "string"
              },
              "page": {
                "type": "string"
              }
            }
          }
        ]
      }
    },
    "material_type": {
      "type": ["string", "null"]
    },
    "purpose_made": {
      "type": ["boolean", "null"],
      "description": "Designed specifically for LED diffusion"
    },
    "notes": {
      "type": ["string", "null"]
    },
    "optical": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "color_rendition": {
          "type": ["integer", "string", "null"],
          "description": "Rating 1-5"
        },
        "light_transmission": {
          "type": ["integer", "string", "null"],
          "description": "Rating 1-5"
        },
        "diffusivity": {
          "type": ["integer", "string", "null"],
          "description": "Rating 1-5"
        },
        "tinted": {
          "type": ["string", "null"],
          "description": "T tinted, C clear, T&C both"
        }
      }
    },
    "physical": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "flexible": {
          "type": ["boolean", "string", "null"],
          "description": "F flexible, R rigid"
        },
        "fire_retardant": {
          "type": ["boolean", "null"]
        },
        "sample_thickness": {
          "type": ["number", "string", "null"],
          "description": "Thickness in mm"
        },
        "sizes_available": {
          "type": ["string", "null"]
        },
        "properties": {
          "type": ["string", "null"]
        }
      }
    },
    "pricing": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "price_range": {
          "type": ["string", "null"],
          "description": "$ to $$$$$"
        }
      }
    },
    "links": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "product": {
          "type": ["string", "null"]
        }
      }
    },
    "image": {
      "$ref": "common.json#/definitions/image"
    },
    "images": {
      "$ref": "common.json#/definitions/images"
    },
    "related": {
      "$ref": "common.json#/definitions/related"
    },
    "dead_links": {
      "$ref": "common.json#/definitions/dead_links"
    }
  }
}
